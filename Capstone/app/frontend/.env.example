# ────────────────────────────────────────────────────────────
# RescueMind AI — Environment Variables
# ────────────────────────────────────────────────────────────
# Copy this file to .env.local and fill in the values.
# cp .env.example .env.local
# ────────────────────────────────────────────────────────────

# Supabase
# Get these from your Supabase project dashboard (Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Google Gemini AI (optional)
# Get a free API key: https://aistudio.google.com/app/apikey
# Without this key, the system runs in offline-only mode.
GEMINI_API_KEY=your-gemini-api-key

# AI Service (Render — optional)
# If set, the classify API proxies Transformers.js inference here
# instead of running it in the Vercel serverless function.
# Example: https://rescuemind-ai-service.onrender.com
AI_SERVICE_URL=

# App Settings
NEXT_PUBLIC_APP_URL=http://localhost:3000
