# ── RescueMind Admin — Environment Variables ──────────────
#
# Copy this file to .env.local and fill in the values.
# Use the SAME Supabase project as your main app.
#
#   cp .env.example .env.local

# Supabase (same project as main frontend)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# ⚠️ REQUIRED for admin dashboard to see ALL reports
# Get this from Supabase Dashboard → Project Settings → API → service_role key
# Without this, RLS will only show reports where user_id matches the admin's ID.
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# App URL
NEXT_PUBLIC_APP_URL=http://localhost:3001
